        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "overflow": "hidden"
          },
          "_name": "footer04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer4\" group=\"Footers\" global=\"\" once=\"footers\" mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"range\" inline=\"\" title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline=\"\" title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax=\"\">\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#2e481a\" selected=\"\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked=\"\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#2e481a\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <input type=\"range\" inline=\"\" title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay &amp;&amp; bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay &amp;&amp; bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"container\">\n        <div class=\"media-container-row align-center mbr-white\">\n            <div class=\"col-12\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".media-container-row .mbr-text\" data-app-placeholder=\"Type Text\">\n                    © Copyright 2025 Mobirise - All Rights Reserved\n                </p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vhBFoiiETh",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {},
          "_anchor": "footer04-9"
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = \"video\")": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".card-wrapper": {
              "background": "@wrapBgColor",
              "@media (max-width: 767px)": {
                "padding": "2rem 1.5rem"
              },
              "@media (min-width: 768px) and (max-width: 991px)": {
                "padding": "2.25rem"
              },
              "@media (min-width: 992px)": {
                "padding": "4rem"
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "color": "#000000",
              "text-align": "left"
            },
            ".card-title, .card-box": {
              "text-align": "center",
              "color": "#000000"
            },
            ".counter-container": {
              "ul": {
                "margin": "0",
                "padding-left": "2.25rem",
                "list-style": "none",
                "li": {
                  "position": "relative",
                  "list-style": "none",
                  "margin-bottom": "2rem",
                  "&:before": {
                    "position": "absolute",
                    "left": "-1.5em",
                    "content": "\"\"",
                    "display": "flex",
                    "justify-content": "center",
                    "align-items": "center",
                    "color": "@iconColor",
                    "background-color": "@iconColor",
                    "width": "0.5em",
                    "height": "0.5em",
                    "top": "0.4em",
                    "border-radius": "50%"
                  }
                }
              }
            },
            ".mbr-text UL": {
              "text-align": "left"
            }
          },
          "_name": "article20",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article07\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n  'mbr-fullscreen': fullScreen,\n  'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"8\" max=\"12\" step=\"1\" value=\"10\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showTitle\">\n    <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n    <input type=\"color\" name=\"iconColor\" title=\"Color\" value=\"#9fe870\">\n    <input type=\"color\" title=\"Wrap Bg\" name=\"wrapBgColor\" value=\"#ffffff\">\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n      <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n    </fieldset>\n    <header condition=\"bg.type === 'video'\">Fallback Image</header>\n    <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"card col-md-12 col-lg-{{contentWidth}}\">\n        <div class=\"card-wrapper\">\n          <div class=\"col-12 content-head mt-3\" mbr-if=\"showSubtitle || showTitle\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n              <b>List</b>\n            </h3>\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n            Press \"Enter\" to add more items to the list.\n            </h5>\n          </div>\n          <div class=\"card-box align-left mt-4\">\n            <div class=\"counter-container mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n              <ul>\n                <li><b>OYO STATE POLIO &amp; HEALTH EMERGENCIES EFFORTS:\n</b></li><li><b>KEY MESSAGE\n</b></li><li><b>Polio eradication is a global public health success story, with Africa now free of wild poliovirus.\n</b></li><li><b>Although cVPV is still a challenge in Nigeria, the last case for Oyo State was confirmed in the year 2025. With strong measures recently ongoing to ensure sustained population immunity so outbreak of cVPV2 continnnue to be a history in Oyo state\n</b></li><li><b>The same systems used for polio are now critical for detecting and responding to other infectious diseases.\n</b></li><li><b>Sustaining high immunization coverage is essential to prevent both polio and other vaccine-preventable diseases.\n</b></li><li><b>OYO State of Nigeria and Nigeria\n</b></li><li><b>Polio eradication efforts in Oyo State and Nigeria are among the most extensive in the world and have achieved major milestones, including interruption of wild poliovirus transmission\n</b></li><li><b>Key Activities:\n</b></li><li><b>Mass Immunization Campaigns (SIAs):\n</b></li><li><b>Nationwide house-to-house vaccination targeting children under 5 years. \n</b></li><li><b>Routine Immunization Strengthening:\n</b></li><li><b>Integration of Oral Polio Vaccine (OPV) into national immunization schedules. \n</b></li><li><b>&nbsp;Emergency Operations Centres (EOCs):\n</b></li><li><b>Coordinating outbreak response and monitoring progress at national and state levels. \n</b></li><li><b>Acute Flaccid Paralysis (AFP) Surveillance:\n</b></li><li><b>Detecting suspected polio cases through health facilities and community informants. \n</b></li><li><b>Environmental Surveillance:\n</b></li><li><b>Testing sewage samples for poliovirus circulation. \n</b></li><li><b>Community Engagement &amp; Social Mobilization:\n</b></li><li><b>Involving religious leaders, traditional rulers, and volunteers. \n</b></li><li><b>Cross-border Surveillance &amp; Vaccination:\n</b></li><li><b>Targeting mobile and hard-to-reach populations. \n</b></li><li><b>Rapid Surveillance Assessments (RSA):\n</b></li><li><b>Strengthening detection systems and closing surveillance gaps. \n</b></li><li><b>Polio Emergency Action Plan (NPEAP):\n</b></li><li><b>Strategic framework guiding eradication activities. \n</b></li><li><b>Africa (African Region): We align with the regional office activities as highlighted below:\n</b></li><li><b>Key Activities:\n</b></li><li><b>•\t“Kick Polio Out of Africa” Campaign (1996):\n</b></li><li><b>Political and community mobilization across the continent. \n</b></li><li><b>•\tMass Vaccination of Millions of Children:\n</b></li><li><b>Reaching even remote and conflict-affected areas. \n</b></li><li><b>•\tIntegrated Surveillance Systems:\n</b></li><li><b>Laboratory networks and field surveillance teams across countries. \n</b></li><li><b>•\tOutreach to Hard-to-Reach Populations:\n</b></li><li><b>Mobile teams, transit vaccination points, and community informants. \n</b></li><li><b>•\tUse of Polio Infrastructure for Other Diseases:\n</b></li><li><b>Supporting responses to Ebola, COVID-19, measles, cholera, etc. \n</b></li><li><b>•\tContainment of Vaccine-Derived Poliovirus (cVDPV): Targeted immunization in low-coverage areas.\n</b></li><li><b>Global (Global Polio Eradication Initiative – GPEI)\n</b></li><li><b>We also align with the Global Polio eradication Initiative (GPEI)\n</b></li><li><b>Launched in 1988, the global initiative has reduced polio cases by over 99% worldwide.\n</b></li><li><b>Key Activities:\n</b></li><li><b>•\tGlobal Immunization Strategy:\n</b></li><li><b>Ensuring every child receives multiple doses of polio vaccine. \n</b></li><li><b>•\tPolio Endgame Strategy (2019–2023 &amp; beyond): \n</b></li><li><b>o\tEradication (vaccination + surveillance) \n</b></li><li><b>o\tIntegration (health system strengthening) \n</b></li><li><b>o\tContainment (preventing re-emergence) \n</b></li><li><b>•\tGlobal Laboratory Network:\n</b></li><li><b>Rapid detection and confirmation of poliovirus. \n</b></li><li><b>•\tOutbreak Response Campaigns:\n</b></li><li><b>Rapid vaccination following detection of cases. \n</b></li><li><b>•\tPartnership Coordination:\n</b></li><li><b>WHO, UNICEF, CDC, Rotary International, Gates Foundation. \n</b></li><li><b>Monitoring &amp; Certification:\n</b></li><li><b>Regions declared polio-free after ≥3 years without cases.\n</b></li><li><b>EPIDEMIC-PRONE DISEASES (IDSR PRIORITY DISEASES)\n</b></li><li><b>Under the Integrated Disease Surveillance and Response (IDSR) framework, the following epidemic-prone diseases are prioritized:\n</b></li><li><b>Viral Diseases:\n</b></li><li><b>•\tEbola Virus Disease (EVD) \n</b></li><li><b>•\tLassa Fever \n</b></li><li><b>•\tYellow Fever \n</b></li><li><b>•\tMeasles \n</b></li><li><b>•\tCOVID-19 \n</b></li><li><b>•\tDengue Fever \n</b></li><li><b>Bacterial Diseases:\n</b></li><li><b>•\tCholera \n</b></li><li><b>•\tCerebrospinal Meningitis \n</b></li><li><b>•\tPlague \n</b></li><li><b>•\tTyphoid Fever \n</b></li><li><b>Other Priority Conditions:\n</b></li><li><b>•\tAcute Viral Hemorrhagic Fevers \n</b></li><li><b>•\tInfluenza (Pandemic-prone) \n</b></li><li><b>These diseases require immediate reporting, rapid response, and outbreak investigation.\n</b></li><li><b>💉 VACCINE-PREVENTABLE DISEASES (VPDs)\n</b></li><li><b>These are diseases targeted through routine immunization and supplementary campaigns:\n</b></li><li><b>Childhood Vaccine-Preventable Diseases:\n</b></li><li><b>•\tPoliomyelitis (Polio) \n</b></li><li><b>•\tMeasles \n</b></li><li><b>•\tTuberculosis (BCG) \n</b></li><li><b>•\tDiphtheria \n</b></li><li><b>•\tPertussis (Whooping cough) \n</b></li><li><b>•\tTetanus \n</b></li><li><b>•\tHepatitis B \n</b></li><li><b>•\tHaemophilus influenzae type b (Hib) \n</b></li><li><b>•\tPneumococcal disease \n</b></li><li><b>•\tRotavirus diarrhea \n</b></li><li><b>Additional VPDs (Campaign or Special Programs):\n</b></li><li><b>•\tYellow Fever \n</b></li><li><b>•\tHuman Papillomavirus (HPV) \n</b></li><li><b>•\tMeningococcal meningitis \n</b></li><li><b>•\tCOVID-19\n</b></li><li><b>🔗 LINK BETWEEN POLIO PROGRAMME &amp; IDSR\n</b></li><li><b>Polio eradication infrastructure supports broader disease surveillance:\n</b></li><li><b>•\tStrengthened surveillance systems used for multiple diseases \n</b></li><li><b>•\tShared laboratory networks \n</b></li><li><b>•\tRapid response teams for outbreaks \n</b></li><li><b>•\tCommunity-based reporting systems\n</b></li><li><b>Polio programmes have significantly contributed to controlling diseases like measles, cholera, Ebola, and COVID-19\n</b></li><li><b><br></b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li><li><b>\n</b></li>\n              </ul>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
          "_cid": "vhBFMniRLI",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "article20-a"
        }
      ]
    },
    "Health Interventions.html": {
      "settings": {
        "title": "Health Interventions",
        "order": "4"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
            "width": "100%",
