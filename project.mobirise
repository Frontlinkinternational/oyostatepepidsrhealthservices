          "_name": "menu01",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu1\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\t<mbr-parameters>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"5\" step=\"0.1\" value=\"2.6\" condition=\"showLogo\">\n\t\t<input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n\t\t<select title=\"Menu Items Align\" name=\"contentAlign\" condition=\"showItems\">\n\t\t\t<option value=\"1\" selected>Left</option>\n\t\t\t<option value=\"2\">Center</option>\n\t\t\t<option value=\"3\">Right</option>\n\t\t</select>\n\t\t<input type=\"checkbox\" title=\"Icons\" name=\"showIcons\">\n\t\t<select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\" selected>3</option>\n\t\t\t<option value=\"4\">4</option>\n\t\t</select>\n\t\t<input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#000000\" condition=\"showIcons\">\n\t\t<input type=\"checkbox\" title=\"Button\" name=\"showButtons\" checked>\n\t\t<header>Styles</header>\n\t\t<input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"none\">\n\t\t<input type=\"checkbox\" title=\"Transparent\" name=\"transparent\" checked>\n\t\t<input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n\t\t<input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"transparent\">\n\t\t<input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#ffffff\">\n\t\t<input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#000000\">\n\t</mbr-parameters>\n\n\t<nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"navbar-brand\">\n\t\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t\t\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/oyo20who-96x54.png\" alt=\"Mobirise Website Builder\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t\t\n\t\t\t\t</span>\n\t\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-black\" data-app-selector=\".navbar-caption\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Oyo Health</a></span>\n\t\t\t</div>\n\t\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<div class=\"hamburger\">\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t\t<span></span>\n\t\t\t\t</div>\n\t\t\t</button>\n\t\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n\t\t\t\t<ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Home</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"About Us.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" aria-expanded=\"false\">About</a>\n\t\t\t\t\t</li>\n\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"Districts.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Districts&nbsp;</a>\n\t\t\t\t\t</li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"Polio & Emergencies.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Polio &amp; Emergencies</a></li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"Health Interventions.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Services</a></li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"Partners.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Partners</a></li></ul>\n\t\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-phone mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-letter mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 2\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-map-pin mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t\t<a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-shopping-cart mobi-mbri\"></span>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t\t<div mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-buttons mbr-section-btn\"><a class=\"btn btn-primary\" href=\"index.html\" data-app-placeholder=\"Type Text\">More</a></div>\n\t\t\t</div>\n\t\t</div>\n\t</nav>\n</section>",
          "_cid": "vhyfSEkG3h",
          "_anchor": "menu01-0",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-subtitle DIV": {
              "text-align": "justify"
            }
          },
          "_name": "article11",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article11\" group=\"Article\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n       <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\" condition=\"fullScreen == false\">\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" step=\"1\" value=\"10\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">        \n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\">\n    </div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"title col-md-12 col-lg-{{textWidth}}\">\n                <h3 class=\"mbr-section-title mbr-fonts-style align-center mt-0 mb-0\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-5\"><b>Health Services&nbsp;</b></h3>\n                <h4 class=\"mbr-section-subtitle align-center mbr-fonts-style mt-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-7\">Key Focus Areas\n<div>\n</div><div>&nbsp;Ensuring populations are protected from health emergencies and epidemic threats</div><br><div>\n</div><div>&nbsp;Key Focus Areas:</div><br><div>\n</div><div>• Pandemic preparedness and response systems\n</div><div>• Surveillance systems (e.g., IDSR) for early detection\n</div><div>• Rapid outbreak response (e.g., cholera, Ebola, influenza)\n</div><div>• One Health approach (human, animal, environmental health) expansion\n</div><div>• Antimicrobial Resistance (AMR) tackled</div><br><div>\n</div><div>PROMOTING HEALTH (HEALTHIER POPULATIONS)\n</div><div>Key Focus Areas:</div><br><div>\n</div><div>• Reducing risk factors (tobacco, alcohol, unhealthy diet, air pollution)\n</div><div>• Tackling noncommunicable diseases (NCDs) like hypertension, diabetes\n</div><div>• Improving mental health services\n</div><div>• Addressing social determinants of health\n</div><div>• Promoting healthier lifestyles and environments</div><br><div>\n</div><div>PROVIDING HEALTH SERVICES (UNIVERSAL HEALTH COVERAGE – UHC)\n</div><div>Ensuring everyone has access to quality health services without financial hardship</div><br><div>\n</div><div>Key Focus Areas:\n</div><div>• Strengthening primary health care (PHC) systems\n</div><div>• Expanding routine immunization programmes\n</div><div>• Improving access to essential medicines and vaccines\n</div><div>• Enhancing health workforce capacity\n</div><div>• Digital health and health system innovation</div><br><div>\n</div><div>1. Improve Reproductive, Maternal, Newborn and Child Health (RMNCH) and Nutrition\n</div><div>This priority focuses on reducing preventable deaths and improving health outcomes across the life cycle of women, newborns, and children.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Strengthen antenatal, delivery, and postnatal care services\n</div><div>• Increase access to skilled birth attendants and emergency obstetric care\n</div><div>• Improve newborn care (early breastfeeding, neonatal resuscitation, care for preterm babies)\n</div><div>• Scale up child survival interventions (IMCI, ORS, zinc, vitamin A)\n</div><div>• Address malnutrition through maternal nutrition, infant and young child feeding practices, and treatment of acute malnutrition</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Reduced maternal, neonatal, and under five mortality\n</div><div>• Improved nutritional status of women and children\n</div><div>• Healthier pregnancies and early childhood development</div><br><div>\n</div><div>2. Accelerate Immunization Programs for Priority Antigens\n</div><div>This priority aims to protect children and communities from vaccine preventable diseases.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Expand routine immunization coverage for priority vaccines (e.g. DPT3, polio, measles, yellow fever)\n</div><div>• Strengthen outreach to hard to reach and underserved populations\n</div><div>• Improve cold chain and vaccine logistics management\n</div><div>• Address vaccine hesitancy through community engagement and communication</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Increased immunization coverage\n</div><div>• Reduced incidence of vaccine preventable diseases\n</div><div>• Prevention of outbreaks and epidemics</div><br><div>\n</div><div>3. Slow Down the Growth Rate of Non Communicable Diseases (NCDs)\n</div><div>This priority addresses the rising burden of chronic diseases.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Promote healthy lifestyles (physical activity, healthy diets, reduced tobacco and alcohol use)\n</div><div>• Early screening for hypertension, diabetes, cancers, and mental health conditions\n</div><div>• Integration of NCD services into primary health care\n</div><div>• Strengthen referral systems and continuity of care</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Early detection and management of NCDs\n</div><div>• Reduced complications and premature deaths\n</div><div>• Lower long term healthcare costs</div><br><div>\n</div><div>4. Reduce the Incidence of HIV, Tuberculosis, and Malaria\n</div><div>This priority targets major communicable diseases that contribute significantly to morbidity and mortality.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Expand HIV testing, treatment, and prevention services\n</div><div>• Improve TB case detection, treatment adherence, and drug resistant TB management\n</div><div>• Scale up malaria prevention (bed nets, indoor residual spraying) and effective treatment\n</div><div>• Strengthen community based and key population interventions</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Reduced new infections\n</div><div>• Improved survival and quality of life\n</div><div>• Progress toward disease elimination goals</div><br><div>\n</div><div>5. Improve Quality of Care and Service Delivery in Primary Health Care Centers (PHCs)\n</div><div>PHCs are the foundation of the health system.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Upgrade PHC infrastructure and essential equipment\n</div><div>• Ensure availability of essential medicines and supplies\n</div><div>• Improve clinical standards, patient safety, and supervision\n</div><div>• Strengthen community trust and utilization of PHC services</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Increased use of PHC services\n</div><div>• Improved patient satisfaction and health outcomes\n</div><div>• Reduced burden on secondary and tertiary facilities</div><br><div>\n</div><div>6. Expand Financial Protection Through Health Insurance and Innovative Financing\n</div><div>This priority reduces financial hardship related to healthcare.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Expand population coverage through health insurance schemes\n</div><div>• Protect vulnerable groups and informal sector workers\n</div><div>• Reduce out of pocket expenditure\n</div><div>• Introduce innovative financing mechanisms (e.g. pooled funds, subsidies)</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Improved access to care regardless of ability to pay\n</div><div>• Reduction in catastrophic health spending\n</div><div>• Stronger and more sustainable health financing system</div><br><div>\n</div><div>7. Increase Availability and Quality of Human Resources for Health (HRH)\n</div><div>A strong health system depends on skilled and motivated workers.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Recruitment and deployment of adequate health workers\n</div><div>• Continuous training and capacity development\n</div><div>• Retention strategies for rural and underserved areas\n</div><div>• Performance management and supportive supervision</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Improved service coverage and quality\n</div><div>• Reduced workforce shortages\n</div><div>• Enhanced morale and productivity</div><br><div>\n</div><div>8. Stimulate Local Production of Health Products\n</div><div>This priority strengthens health security and self reliance.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Support local manufacturing of essential medicines and vaccines\n</div><div>• Encourage production of medical supplies (e.g. bed nets, diagnostics, therapeutics)\n</div><div>• Improve regulatory and quality assurance systems\n</div><div>• Foster public–private partnerships and innovation</div><br><div>Expected outcomes:</div><div>\n</div><div>• Reduced dependence on imports\n</div><div>• Improved supply security and affordability\n</div><div>• Job creation and economic growth</div><br><div>\n</div><div>9. Revitalize Tertiary and Quaternary Hospitals for Specialized Care\n</div><div>This priority ensures access to advanced and specialized medical services.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Upgrade diagnostic and treatment technologies\n</div><div>• Strengthen specialized clinical training and research\n</div><div>• Improve referral and counter referral systems\n</div><div>• Enhance governance and efficiency of tertiary facilities</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Better management of complex conditions\n</div><div>• Reduced need for medical tourism\n</div><div>• Stronger centers of excellence</div><br><div>\n</div><div>10. Improve Pandemic Prevention, Detection, Preparedness and Response\n</div><div>This priority builds resilience to public health emergencies.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Strengthen disease surveillance and early warning systems\n</div><div>• Build laboratory and diagnostic capacity\n</div><div>• Develop emergency preparedness and response plans\n</div><div>• Improve risk communication and community engagement</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Faster detection of outbreaks\n</div><div>• More effective emergency response\n</div><div>• Reduced health, social, and economic impact of pandemics</div><br><div>\n</div><div>11. Improve Regulation and Regulatory Processes\n</div><div>Strong regulation ensures safety, quality, and trust in the health system.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Strengthen regulation of medicines, vaccines, and medical devices\n</div><div>• Improve licensing and accreditation of health facilities and professionals\n</div><div>• Enhance enforcement and transparency\n</div><div>• Streamline regulatory processes to reduce delays</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Higher safety and quality standards\n</div><div>• Increased confidence in health services and products\n</div><div>• Reduced circulation of substandard and counterfeit products</div><br><div>\n</div><div>12. Strengthen Health Data Collection, Reporting and Use\n</div><div>Data driven decision making is essential for effective health systems.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Improve routine health information systems\n</div><div>• Standardize core indicators and reporting tools\n</div><div>• Build capacity for data analysis and use at all levels\n</div><div>• Use data for planning, monitoring, and accountability</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Better evidence based decisions\n</div><div>• Improved monitoring of health programs\n</div><div>• Enhanced transparency and accountability</div><br><div>\n</div><div>13. Accelerate Inter Sectoral Social Welfare Through the Social Action Fund\n</div><div>Health outcomes are influenced by social determinants.</div><br><div>\n</div><div>Key focus areas:\n</div><div>• Coordinate health with social welfare, education, and other sectors\n</div><div>• Target vulnerable populations with integrated support\n</div><div>• Improve social protection and emergency assistance mechanisms\n</div><div>• Strengthen governance and coordination of the Social Action Fund</div><br><div>\n</div><div>Expected outcomes:\n</div><div>• Reduced health inequities\n</div><div>• Improved social inclusion and resilience\n</div><div>• Stronger multisectoral collaboration\n</div><div><br></div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div><div>\n</div></h4>\n                <div class=\"mbr-section-btn align-center mt-4\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a class=\"btn btn-secondary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                        Learn more\n                    </a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "vhE1DV1bwP",
          "_anchor": "article11-d",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        }
      ]
    },
    "Partners.html": {
      "settings": {
        "title": "Partners",
        "order": "5"
      },
      "components": [
        {
          "alias": false,
          "_styles": {
            "z-index": "1000",
